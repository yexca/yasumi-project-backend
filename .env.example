# Copy this file to .env for local Docker Compose runs.
# Do not use these local-only secrets outside development.

YASUMI_APP_ENV=local

YASUMI_DOCKER_IMAGE_REPOSITORY=yexca/yasumi-backend
YASUMI_DOCKER_IMAGE_TAG=0.1.0

YASUMI_HTTP_HOST_PORT=7659
YASUMI_HTTP_PORT=7659
YASUMI_HTTP_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4175,http://localhost:4175
YASUMI_HTTP_READ_HEADER_TIMEOUT=5s
YASUMI_HTTP_SHUTDOWN_TIMEOUT=10s
YASUMI_HTTP_REQUEST_TIMEOUT=10s

YASUMI_LOG_LEVEL=info
YASUMI_LOG_FORMAT=json

YASUMI_AUTH_DEV_TOKEN=local-dev-session-token
YASUMI_AUTH_DEV_USER_ID=00000000-0000-4000-8000-000000000001
YASUMI_AUTH_DEV_DISPLAY_NAME=Yasumi User

YASUMI_SYNC_TOKEN_SECRET=local-dev-sync-secret-change-me
YASUMI_SYNC_TOKEN_TTL=15m

YASUMI_POSTGRES_HOST_PORT=5432
YASUMI_POSTGRES_DB=yasumi
YASUMI_POSTGRES_USER=yasumi
YASUMI_POSTGRES_PASSWORD=yasumi

YASUMI_POWERSYNC_URL=http://powersync:8080
YASUMI_POWERSYNC_HOST_PORT=8081

YASUMI_FRONTEND_HOST_PORT=5173
VITE_BACKEND_BASE_URL=http://127.0.0.1:7659
VITE_POWERSYNC_ENDPOINT=http://127.0.0.1:8081
